        make("UIPadding", { PaddingLeft=UDim.new(0,14), PaddingRight=UDim.new(0,14) }, btn)

        -- Aktif göstergesi (üst çizgi)
        local indicator = make("Frame", {
            Size            = UDim2.new(1, 0, 0, 2),
            Position        = UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = Theme.AccentLight,
            BorderSizePixel = 0,
            BackgroundTransparency = 1,
        }, btn)
        make("UICorner", { CornerRadius = UDim.new(0, 2) }, indicator)
        make("UIGradient", { Color = ColorSequence.new(Theme.Accent, Theme.AccentLight), Rotation = 90 }, indicator)

        -- İçerik scroll frame
        local content = make("ScrollingFrame", {
            Size            = UDim2.new(1, 0, 1, 0),
            Position        = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.TextDim,
            CanvasSize      = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ClipsDescendants = true,
