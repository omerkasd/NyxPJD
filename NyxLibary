        SortOrder       = Enum.SortOrder.LayoutOrder,
    }, notifContainer)

    -- ======================================================
    -- TAB YÖNETİMİ
    -- ======================================================
    local tabs       = {}
    local activeTab  = nil

    local function switchTab(tabObj)
        if activeTab == tabObj then return end
        -- Eski tab içeriğini gizle
        if activeTab then
            tween(activeTab.content, { Position = UDim2.new(-1, 0, 0, 0), BackgroundTransparency = 1 }, 0.2, Enum.EasingStyle.Quart)
