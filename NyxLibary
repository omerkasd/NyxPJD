            if activeTab.indicator then
                tween(activeTab.indicator, { BackgroundTransparency = 1 }, 0.15)
            end
        end
        -- Yeni tab içeriğini göster
        activeTab = tabObj
        tabObj.content.Position = UDim2.new(1, 0, 0, 0)
        tween(tabObj.content, { Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 }, 0.22, Enum.EasingStyle.Quart)
        tween(tabObj.btn, { TextColor3 = Theme.AccentLight }, 0.15)
        if tabObj.indicator then
            tween(tabObj.indicator, { BackgroundTransparency = 0 }, 0.15)
        end
    end

    -- ======================================================
    -- WINDOW OBJESİ
    -- ======================================================
    local winObj = {}

    -- Tab ekle
    function winObj:Tab(name)
